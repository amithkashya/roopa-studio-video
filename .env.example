PORT=3000
DATABASE_URL=
DATABASE_SSL=false

# Protect the admin booking list endpoint and page usage.
ADMIN_API_KEY=change-this-admin-key

# Optional email notifications for new bookings.
BOOKING_TO_EMAIL=your-booking-email@example.com
SMTP_HOST=smtp.example.com
